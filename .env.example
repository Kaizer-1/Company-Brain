# Copy this file to .env and adjust values for your environment.
# .env is gitignored — never commit real credentials.

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Postgres
POSTGRES_USER=company_brain
POSTGRES_PASSWORD=password
POSTGRES_DB=company_brain

# App
APP_NAME=Company Brain
DEBUG=false

# Extraction pipeline (Phase 2B) — the LLM extraction + eval harness talks to OpenRouter.
# Get a key at https://openrouter.ai/keys. Required only to RUN extraction/eval; the rest
# of the stack and the test suite run without it (the real-API smoke test skips when unset).
OPENROUTER_API_KEY=sk-or-v1-your-key-here